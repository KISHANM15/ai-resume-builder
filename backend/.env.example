PORT=8787
FRONTEND_URL=http://localhost:5173

# AI suggestions — use ONE of these (Groq has a free tier; no card required for signup):
# https://console.groq.com → API keys
GROQ_API_KEY=
# Optional Groq model if the default fails (see Groq docs for current IDs)
# GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (paid / billing). Leave empty if you only use Groq.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# If BOTH GROQ_API_KEY and OPENAI_API_KEY are set, Groq is used unless you force:
# LLM_PROVIDER=openai

# Optional: how many times to retry on HTTP 429. Default 5.
# OPENAI_RATE_LIMIT_RETRIES=5

# Firebase Admin — one of:
# Path to service account JSON (download from Firebase > Project settings > Service accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=
# Or inline JSON (e.g. in cloud — use single-line or escaped)
# FIREBASE_SERVICE_ACCOUNT_JSON=
